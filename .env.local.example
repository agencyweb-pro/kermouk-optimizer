# ─── PayPal Configuration ──────────────────────────────────────────────────────
# Remplacez par votre Client ID PayPal (sandbox ou live)
# Pour obtenir votre Client ID :
#   1. Allez sur https://developer.paypal.com
#   2. Créez une application dans "My Apps & Credentials"
#   3. Copiez le "Client ID" (sandbox pour les tests, live pour la production)

NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# ─── Mode ──────────────────────────────────────────────────────────────────────
# "sandbox" pour les tests, "production" pour le vrai paiement
NEXT_PUBLIC_PAYPAL_MODE=sandbox
